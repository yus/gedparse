{
  "name": "gedparse",
  "version": "1.0.0",
  "description": "GEDCOM 5.5.1 to 7.0 migration tool with full validation",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "test": "node --test tests/*.test.js",
    "build": "echo 'Build complete'",
    "cap:init": "npx cap init gedparse com.yus.gedparse",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "cap:build": "npx cap sync && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "inquirer": "^9.2.12",
    "@capacitor/android": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/filesystem": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@capacitor/cli": "^6.1.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yus/gedparse.git"
  },
  "keywords": ["gedcom", "migration", "genealogy", "validator"],
  "author": "yus",
  "license": "MIT",
  "packageManager": "yarn@4.0.2"
}
